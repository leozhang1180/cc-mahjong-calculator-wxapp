<!-- pages/index/index.wxml -->
<view class="page-container">

  <!-- 玩家分数总览 -->
  <view class="score-header">
    <view wx:for="{{positionItems}}" wx:key="id" class="score-item">
      <view class="pos-label {{item.isDealer ? 'dealer-label' : ''}}">
        {{item.label}}{{item.isDealer ? '(庄)' : ''}}
      </view>
      <view class="player-name">{{item.name}}</view>
      <view class="player-score {{players[index].totalScore >= 0 ? 'score-positive' : 'score-negative'}}">
        {{players[index].totalScore > 0 ? '+' : ''}}{{players[index].totalScore}}
      </view>
    </view>
  </view>

  <scroll-view scroll-y class="scroll-area">
    <view class="content-wrap">

      <!-- 谁胡了 -->
      <view class="card">
        <view class="section-title">🀄 谁胡了？</view>
        <view class="player-grid">
          <view
            wx:for="{{positionItems}}"
            wx:key="id"
            class="player-btn {{winner === item.id ? 'player-btn-active' : ''}}"
            data-pos="{{item.id}}"
            bindtap="onSelectWinner"
          >
            <view class="pos-tag">{{item.label}}</view>
            <view class="player-btn-name">{{item.name}}</view>
          </view>
        </view>
      </view>

      <!-- 胡牌详情 -->
      <view class="card" wx:if="{{winner}}">
        <view class="section-title">⚡ 胡牌详情</view>
        <view class="row gap-16 mb-24">
          <view
            class="type-btn {{isSelfDrawn ? 'type-btn-active' : ''}}"
            bindtap="onSelectSelfDrawn"
          >自摸</view>
          <view
            class="type-btn {{!isSelfDrawn && loser && loser !== 'All' ? 'type-btn-active' : ''}}"
            bindtap="onSelectDiscard"
          >点炮</view>
        </view>

        <view class="player-grid" wx:if="{{!isSelfDrawn}}">
          <view
            wx:for="{{positionItems}}"
            wx:key="id"
            wx:if="{{item.id !== winner}}"
            class="player-btn {{loser === item.id ? 'player-btn-loser' : ''}}"
            data-pos="{{item.id}}"
            bindtap="onSelectLoser"
          >
            <view class="pos-tag">{{item.label}}</view>
            <view class="player-btn-name">{{item.name}}</view>
          </view>
        </view>
      </view>

      <!-- 加番项 -->
      <view class="card" wx:if="{{winner}}">
        <view class="section-title-row">
          <view class="section-title">🎴 加番项</view>
          <view
            class="manguan-btn {{isManGuan ? 'manguan-btn-active' : ''}}"
            bindtap="onToggleManGuan"
          >满贯牌型</view>
        </view>

        <view wx:if="{{!isManGuan}}">
          <view wx:for="{{fanGroups}}" wx:key="title" class="fan-group">
            <view class="fan-group-title">{{item.title}}</view>
            <view class="fan-chips">
              <view
                wx:for="{{item.fans}}"
                wx:key="key"
                wx:for-item="fan"
                class="fan-chip {{fan.isSelected ? 'fan-chip-active' : ''}} {{fan.isDisabled ? 'fan-chip-disabled' : ''}}"
                data-fan="{{fan.name}}"
                bindtap="onToggleFan"
              >{{fan.name}}</view>
            </view>
          </view>
        </view>

        <view wx:else class="manguan-tip">
          天胡/地胡等满贯牌型，直接按封顶番数计算。
        </view>
      </view>

      <!-- 蛋分 -->
      <view class="card">
        <view class="section-title-row">
          <view class="section-title">🥚 蛋分累计</view>
          <view class="egg-total">总蛋: {{totalEggs}}</view>
        </view>

        <view class="egg-row" wx:for="{{positionItems}}" wx:key="id" wx:for-item="pItem">
          <view class="egg-player-name">{{pItem.name}}</view>
          <view class="egg-controls">
            <view class="egg-btn egg-btn-minus" data-pos="{{pItem.id}}" data-delta="{{-5}}" bindtap="onEggChange">-5</view>
            <view class="egg-btn egg-btn-minus" data-pos="{{pItem.id}}" data-delta="{{-1}}" bindtap="onEggChange">-1</view>
            <view class="egg-val">{{eggScores[pItem.id]}}</view>
            <view class="egg-btn egg-btn-plus" data-pos="{{pItem.id}}" data-delta="{{1}}" bindtap="onEggChange">+1</view>
            <view class="egg-btn egg-btn-plus" data-pos="{{pItem.id}}" data-delta="{{5}}" bindtap="onEggChange">+5</view>
          </view>
        </view>
      </view>

      <!-- 结算明细预览 -->
      <view class="card preview-card" wx:if="{{showPreview}}">
        <view class="section-title" style="color:#6ee7b7">📊 结算明细预览</view>
        <view class="preview-row" wx:for="{{previewScores}}" wx:key="pos">
          <view class="preview-left">
            <view class="preview-name-row">
              <text class="preview-name">{{item.name}}</text>
              <text class="tag tag-winner" wx:if="{{item.isWinner}}">胡</text>
              <text class="tag tag-loser" wx:if="{{item.isLoser && !item.isWinner}}">点</text>
              <text class="tag tag-dealer" wx:if="{{item.isDealer}}">庄</text>
            </view>
            <view class="preview-sub">
              <text wx:if="{{item.huNet !== 0}}" style="margin-right:12rpx">胡: {{item.huNet > 0 ? '+' : ''}}{{item.huNet}}</text>
              <text wx:if="{{item.eggNet !== 0}}">蛋: {{item.eggNet > 0 ? '+' : ''}}{{item.eggNet}}</text>
            </view>
          </view>
          <view class="preview-score {{item.scoreClass}}">{{item.totalNetStr}}</view>
        </view>

        <view class="fan-tags" wx:if="{{currentHuInfo}}">
          <view class="fan-tag-chip" wx:for="{{currentHuInfo.fans}}" wx:key="index">{{item}}</view>
          <view class="fan-score-chip">{{currentHuInfo.totalFans}}番 ({{currentHuInfo.huScore}}分)</view>
        </view>
      </view>

      <!-- 提交按钮 -->
      <view
        class="submit-btn {{canSubmit ? '' : 'submit-btn-disabled'}}"
        bindtap="onSubmit"
      >确认并保存结算</view>

      <view style="height: 40rpx"></view>
    </view>
  </scroll-view>
</view>
