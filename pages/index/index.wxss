/* pages/index/index.wxss */

.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #fdfcf0;
}

.score-header {
  display: flex;
  background: #ecfdf5;
  border-bottom: 1rpx solid #d1fae5;
  padding: 16rpx;
  gap: 8rpx;
  flex-shrink: 0;
}

.score-item {
  flex: 1;
  text-align: center;
}

.pos-label {
  font-size: 18rpx;
  font-weight: 700;
  color: #6ee7b7;
  margin-bottom: 4rpx;
}

.dealer-label {
  color: #059669;
}

.player-name {
  font-size: 22rpx;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.player-score {
  font-size: 32rpx;
  font-weight: 900;
  font-variant-numeric: tabular-nums;
}

.scroll-area {
  flex: 1;
  overflow: hidden;
}

.content-wrap {
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #d1fae5;
  box-shadow: 0 2rpx 8rpx rgba(6, 95, 70, 0.06);
}

.section-title {
  font-size: 20rpx;
  font-weight: 700;
  color: #059669;
  letter-spacing: 3rpx;
  margin-bottom: 24rpx;
}

.section-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title-row .section-title {
  margin-bottom: 0;
}

.player-grid {
  display: flex;
  gap: 12rpx;
}

.player-btn {
  flex: 1;
  background: #f0fdf4;
  border: 2rpx solid #d1fae5;
  border-radius: 16rpx;
  padding: 16rpx 8rpx;
  text-align: center;
  transition: all 0.15s;
}

.player-btn-active {
  background: #059669;
  border-color: #059669;
  color: #ffffff;
  transform: scale(1.04);
  box-shadow: 0 4rpx 16rpx rgba(5, 150, 105, 0.3);
}

.player-btn-loser {
  background: #ef4444;
  border-color: #ef4444;
  color: #ffffff;
}

.pos-tag {
  font-size: 18rpx;
  opacity: 0.7;
  margin-bottom: 4rpx;
}

.player-btn-name {
  font-size: 22rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.row {
  display: flex;
}

.gap-16 {
  gap: 16rpx;
}

.mb-24 {
  margin-bottom: 24rpx;
}

.type-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border: 2rpx solid #d1fae5;
  border-radius: 16rpx;
  font-weight: 700;
  font-size: 28rpx;
  background: #f0fdf4;
  color: #065f46;
}

.type-btn-active {
  background: #059669;
  border-color: #059669;
  color: #ffffff;
}

.manguan-btn {
  font-size: 20rpx;
  padding: 8rpx 20rpx;
  border-radius: 10rpx;
  background: #ecfdf5;
  color: #059669;
  font-weight: 700;
}

.manguan-btn-active {
  background: #dc2626;
  color: #ffffff;
}

.manguan-tip {
  background: #fef2f2;
  border: 1rpx solid #fecaca;
  border-radius: 16rpx;
  padding: 24rpx;
  color: #991b1b;
  font-size: 24rpx;
}

.fan-group {
  margin-bottom: 24rpx;
}

.fan-group-title {
  font-size: 20rpx;
  font-weight: 700;
  color: #6ee7b7;
  margin-bottom: 12rpx;
}

.fan-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.fan-chip {
  padding: 12rpx 20rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 700;
  background: #ecfdf5;
  color: #065f46;
  border: 2rpx solid transparent;
}

.fan-chip-active {
  background: #059669;
  color: #ffffff;
}

.fan-chip-disabled {
  background: #f3f4f6;
  color: #d1d5db;
}

.egg-total {
  font-size: 20rpx;
  font-weight: 700;
  color: #6ee7b7;
  background: #ecfdf5;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.egg-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(236, 253, 245, 0.3);
  border: 1rpx solid #d1fae5;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
}

.egg-player-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #052e16;
}

.egg-controls {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.egg-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid;
}

.egg-btn-minus {
  background: #ffffff;
  border-color: #fecaca;
  color: #ef4444;
}

.egg-btn-plus {
  background: #ffffff;
  border-color: #d1fae5;
  color: #059669;
}

.egg-val {
  width: 60rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 900;
  color: #065f46;
  font-variant-numeric: tabular-nums;
}

/* Preview card */
.preview-card {
  background: #052e16;
  border-color: #064e3b;
}

.preview-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(6, 78, 59, 0.4);
}

.preview-row:last-of-type {
  border-bottom: none;
}

.preview-left {
  flex: 1;
}

.preview-name-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 6rpx;
}

.preview-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #ffffff;
}

.tag {
  font-size: 16rpx;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  font-weight: 700;
}

.tag-winner {
  background: #fbbf24;
  color: #052e16;
}

.tag-loser {
  background: #ef4444;
  color: #ffffff;
}

.tag-dealer {
  background: #064e3b;
  color: #6ee7b7;
}

.preview-sub {
  font-size: 18rpx;
  color: #6ee7b7;
}

.preview-score {
  font-size: 40rpx;
  font-weight: 900;
  font-variant-numeric: tabular-nums;
}

.score-positive { color: #fbbf24; }
.score-negative { color: #f87171; }
.score-zero { color: #6ee7b7; }

.fan-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(6, 78, 59, 0.4);
}

.fan-tag-chip {
  font-size: 18rpx;
  background: #064e3b;
  color: #6ee7b7;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  border: 1rpx solid #065f46;
}

.fan-score-chip {
  font-size: 18rpx;
  background: #fbbf24;
  color: #052e16;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  font-weight: 700;
}

/* Submit button */
.submit-btn {
  width: 100%;
  height: 96rpx;
  background: #ffffff;
  border: 3rpx solid #059669;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 900;
  color: #059669;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 0 0 #064e3b;
  margin-top: 8rpx;
  transition: all 0.1s;
}

.submit-btn:active {
  box-shadow: none;
  transform: translateY(8rpx);
}

.submit-btn-disabled {
  border-color: #e5e7eb;
  color: #d1d5db;
  background: #f9fafb;
  box-shadow: none;
}
