/* pages/history/history.wxss */
.page-wrap {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #fdfcf0;
}

.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #d1fae5;
  flex-shrink: 0;
}

.top-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #052e16;
}

.reset-btn {
  font-size: 24rpx;
  color: #dc2626;
  font-weight: 700;
  padding: 8rpx 20rpx;
  border: 1rpx solid #fecaca;
  border-radius: 10rpx;
  background: #fef2f2;
}

.list-scroll {
  flex: 1;
  overflow: hidden;
}

.empty-tip {
  text-align: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #6b7280;
  margin-bottom: 12rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: #9ca3af;
  line-height: 1.5;
}

.round-card {
  background: #ffffff;
  border-radius: 20rpx;
  margin: 16rpx 24rpx;
  padding: 28rpx;
  border: 1rpx solid #d1fae5;
  box-shadow: 0 2rpx 8rpx rgba(6, 95, 70, 0.06);
}

.round-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.round-meta {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.round-time {
  font-size: 22rpx;
  color: #6b7280;
}

.round-dealer {
  font-size: 20rpx;
  color: #059669;
  font-weight: 700;
  background: #ecfdf5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.del-btn {
  font-size: 22rpx;
  color: #dc2626;
  padding: 6rpx 16rpx;
  border: 1rpx solid #fecaca;
  border-radius: 8rpx;
}

.round-scores {
  display: flex;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.round-score-item {
  flex: 1;
  text-align: center;
  background: #f0fdf4;
  border-radius: 12rpx;
  padding: 12rpx 4rpx;
}

.round-pos {
  font-size: 18rpx;
  color: #6ee7b7;
  font-weight: 700;
  margin-bottom: 4rpx;
}

.round-name {
  font-size: 20rpx;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #052e16;
  margin-bottom: 6rpx;
}

.round-net {
  font-size: 28rpx;
  font-weight: 900;
  font-variant-numeric: tabular-nums;
}

.score-positive { color: #059669; }
.score-negative { color: #dc2626; }
.score-zero { color: #6b7280; }

.round-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #ecfdf5;
}

.hu-tag {
  font-size: 18rpx;
  background: #ecfdf5;
  color: #059669;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  border: 1rpx solid #d1fae5;
}

.hu-score-tag {
  font-size: 18rpx;
  background: #fbbf24;
  color: #052e16;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-weight: 700;
}

.hu-type-tag {
  font-size: 18rpx;
  background: #dbeafe;
  color: #1e40af;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-weight: 700;
}

/* Modal */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(5, 46, 22, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.modal-box {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  width: 560rpx;
  text-align: center;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.2);
}

.modal-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #052e16;
  margin-bottom: 12rpx;
}

.modal-desc {
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.6;
  margin-bottom: 36rpx;
}

.modal-btns {
  display: flex;
  gap: 16rpx;
}

.modal-cancel {
  flex: 1;
  padding: 24rpx;
  border-radius: 16rpx;
  background: #ecfdf5;
  color: #059669;
  font-weight: 700;
  font-size: 28rpx;
}

.modal-confirm {
  flex: 1;
  padding: 24rpx;
  border-radius: 16rpx;
  background: #dc2626;
  color: #ffffff;
  font-weight: 700;
  font-size: 28rpx;
  box-shadow: 0 6rpx 0 #991b1b;
}
