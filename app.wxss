/* 全局重置 */
/* app.wxss */
page {
  width: 100%;
  max-width: 100vw;
  overflow-x: hidden;
  background-color: #fdfcf0;
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
  -webkit-font-smoothing: antialiased;
  color: #052e16;
  font-size: 28rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1px solid #d1fae5;
}

.section-title {
  font-size: 20rpx;
  font-weight: 700;
  color: #059669;
  text-transform: uppercase;
  letter-spacing: 4rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.btn-primary {
  background: #065f46;
  color: #ffffff;
  border-radius: 20rpx;
  padding: 20rpx 32rpx;
  font-weight: 700;
  font-size: 28rpx;
  border: none;
}

.btn-secondary {
  background: #ecfdf5;
  color: #059669;
  border-radius: 20rpx;
  padding: 20rpx 32rpx;
  font-weight: 700;
  font-size: 28rpx;
  border: none;
}

.score-positive {
  color: #059669;
}

.score-negative {
  color: #dc2626;
}

.score-zero {
  color: #6b7280;
}

.tag {
  font-size: 18rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 700;
}

.tag-winner {
  background: #fbbf24;
  color: #052e16;
}

.tag-loser {
  background: #ef4444;
  color: #ffffff;
}

.tag-dealer {
  background: #064e3b;
  color: #a7f3d0;
}

